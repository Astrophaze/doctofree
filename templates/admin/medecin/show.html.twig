{% extends 'admin/base.html.twig' %}

{% block title %}Dr {{ medecin.prenom }} {{ medecin.nom }}{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Dr {{ medecin.prenom }} {{ medecin.nom }}</h1>
    <a href="{{ path('app_admin_medecin_index') }}" class="btn btn-outline-secondary">Retour</a>
</div>

<table class="table">
    <tbody>
        <tr><th>ID</th><td>{{ medecin.id }}</td></tr>
        <tr><th>Nom</th><td>{{ medecin.nom }}</td></tr>
        <tr><th>Prénom</th><td>{{ medecin.prenom }}</td></tr>
        <tr><th>RPPS</th><td>{{ medecin.rpps }}</td></tr>
        <tr><th>Téléphone</th><td>{{ medecin.telephone }}</td></tr>
        <tr><th>Email</th><td>{{ medecin.email }}</td></tr>
    </tbody>
</table>
{% endblock %}
