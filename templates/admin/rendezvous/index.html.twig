{% extends 'admin/base.html.twig' %}

{% block title %}Rendez-vous{% endblock %}

{% block admin_content %}
<h1 class="h3 mb-4">Rendez-vous</h1>

<table class="table">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Date &amp; heure</th>
            <th>Durée (min)</th>
            <th>Statut</th>
            <th>Motif</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for rendezvou in rendezvouses %}
        <tr>
            <td>{{ rendezvou.id }}</td>
            <td>{{ rendezvou.dateHeure ? rendezvou.dateHeure|date('d/m/Y H:i') : '—' }}</td>
            <td>{{ rendezvou.dureeMinutes }}</td>
            <td>{{ rendezvou.statut }}</td>
            <td>{{ rendezvou.motif }}</td>
            <td>
                <a href="{{ path('app_admin_rendezvous_show', {'id': rendezvou.id}) }}" class="btn btn-outline-primary">Voir</a>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
