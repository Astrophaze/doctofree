{% extends 'admin/base.html.twig' %}

{% block title %}Rendez-vous #{{ rendezvou.id }}{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Rendez-vous #{{ rendezvou.id }}</h1>
    <a href="{{ path('app_admin_rendezvous_index') }}" class="btn btn-outline-secondary">Retour</a>
</div>

<table class="table">
    <tbody>
        <tr><th>ID</th><td>{{ rendezvou.id }}</td></tr>
        <tr><th>Date &amp; heure</th><td>{{ rendezvou.dateHeure ? rendezvou.dateHeure|date('d/m/Y H:i') : '—' }}</td></tr>
        <tr><th>Durée (min)</th><td>{{ rendezvou.dureeMinutes }}</td></tr>
        <tr><th>Statut</th><td>{{ rendezvou.statut }}</td></tr>
        <tr><th>Motif</th><td>{{ rendezvou.motif }}</td></tr>
    </tbody>
</table>
{% endblock %}
