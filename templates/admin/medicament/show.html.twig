{% extends 'admin/base.html.twig' %}

{% block title %}Médicament — {{ medicament.nom }}{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ medicament.nom }}</h1>
    <a href="{{ path('app_admin_medicament_index') }}" class="btn btn-outline-secondary">Retour</a>
</div>

<table class="table">
    <tbody>
        <tr><th>ID</th><td>{{ medicament.id }}</td></tr>
        <tr><th>Nom</th><td>{{ medicament.nom }}</td></tr>
        <tr><th>DCI</th><td>{{ medicament.dci }}</td></tr>
        <tr><th>Forme</th><td>{{ medicament.forme }}</td></tr>
        <tr><th>Dosage</th><td>{{ medicament.dosage }}</td></tr>
    </tbody>
</table>
{% endblock %}
