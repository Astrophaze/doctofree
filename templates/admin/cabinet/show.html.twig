{% extends 'admin/base.html.twig' %}

{% block title %}Cabinet — {{ cabinet.nom }}{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ cabinet.nom }}</h1>
    <a href="{{ path('app_admin_cabinet_index') }}" class="btn btn-outline-secondary">Retour</a>
</div>

<table class="table">
    <tbody>
        <tr><th>ID</th><td>{{ cabinet.id }}</td></tr>
        <tr><th>Nom</th><td>{{ cabinet.nom }}</td></tr>
        <tr><th>Adresse</th><td>{{ cabinet.adresse }}</td></tr>
        <tr><th>Téléphone</th><td>{{ cabinet.telephone }}</td></tr>
    </tbody>
</table>
{% endblock %}
