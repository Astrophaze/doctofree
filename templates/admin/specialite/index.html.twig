{% extends 'admin/base.html.twig' %}

{% block title %}Spécialités{% endblock %}

{% block admin_content %}
<h1 class="h3 mb-4">Spécialités</h1>

<table class="table">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Libellé</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for specialite in specialites %}
        <tr>
            <td>{{ specialite.id }}</td>
            <td>{{ specialite.libelle }}</td>
            <td>{{ specialite.description }}</td>
            <td>
                <a href="{{ path('app_admin_specialite_show', {'id': specialite.id}) }}" class="btn btn-outline-primary">Voir</a>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
