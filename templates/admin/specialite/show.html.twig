{% extends 'admin/base.html.twig' %}

{% block title %}Spécialité — {{ specialite.libelle }}{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ specialite.libelle }}</h1>
    <a href="{{ path('app_admin_specialite_index') }}" class="btn btn-outline-secondary">Retour</a>
</div>

<table class="table">
    <tbody>
        <tr><th>ID</th><td>{{ specialite.id }}</td></tr>
        <tr><th>Libellé</th><td>{{ specialite.libelle }}</td></tr>
        <tr><th>Description</th><td>{{ specialite.description }}</td></tr>
    </tbody>
</table>
{% endblock %}
